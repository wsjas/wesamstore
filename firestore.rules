rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // قواعد تجربة مؤقتة لتشغيل لوحة التحكم والاختبار.
    // بعد التأكد أن كل شيء يعمل، يجب استبدالها بقواعد المدير المحمية.

    match /settings/{docId} { allow read, write: if true; }
    match /config/{docId} { allow read, write: if true; }
    match /products/{docId} { allow read, write: if true; }
    match /orders/{docId} { allow read, create, update, delete: if true; }
    match /service_requests/{docId} { allow read, create, update, delete: if true; }
    match /contact_messages/{docId} { allow read, create, update, delete: if true; }
    match /subscribers/{docId} { allow read, create, update, delete: if true; }
    match /coupons/{docId} { allow read, write: if true; }
    match /notifications/{docId} { allow read, write: if true; }
    match /accounting_transactions/{docId} { allow read, create, update, delete: if true; }
    match /expenses/{docId} { allow read, create, update, delete: if true; }
    match /payments/{docId} { allow read, create, update, delete: if true; }
    match /customers/{docId} { allow read, create, update, delete: if true; }
    match /technicians/{docId} { allow read, create, update, delete: if true; }
    match /admin_users/{docId} { allow read, write: if true; }
    match /audit_logs/{docId} { allow read, create, update, delete: if true; }
    match /suppliers/{docId} { allow read, create, update, delete: if true; }
    match /purchase_orders/{docId} { allow read, create, update, delete: if true; }
    match /inventory_movements/{docId} { allow read, create, update, delete: if true; }
    match /warranties/{docId} { allow read, create, update, delete: if true; }
    match /work_notes/{docId} { allow read, create, update, delete: if true; }
    match /followups/{docId} { allow read, create, update, delete: if true; }
    match /diagnostics/{docId} { allow read, create, update, delete: if true; }
    match /message_templates/{docId} { allow read, create, update, delete: if true; }
    match /error_logs/{docId} { allow read, create, update, delete: if true; }
    match /archived_records/{docId} { allow read, create, update, delete: if true; }
    match /devices/{docId} { allow read, create, update, delete: if true; }
    match /daily_tasks/{docId} { allow read, create, update, delete: if true; }
    match /button_audits/{docId} { allow read, create, update, delete: if true; }
    match /data_exports/{docId} { allow read, create, update, delete: if true; }
    match /appointments/{docId} { allow read, create, update, delete: if true; }
    match /returns/{docId} { allow read, create, update, delete: if true; }
    match /reviews/{docId} { allow read, create, update, delete: if true; }
    match /seo/{docId} { allow read, write: if true; }
    match /notification_rules/{docId} { allow read, write: if true; }
    match /status_templates/{docId} { allow read, create, update, delete: if true; }

    match /homepage_blocks/{docId} { allow read, create, update, delete: if true; }
    match /hero_slides/{docId} { allow read, create, update, delete: if true; }
    match /loyalty_points/{docId} { allow read, create, update, delete: if true; }
    match /device_handover/{docId} { allow read, create, update, delete: if true; }
    match /service_checklists/{docId} { allow read, create, update, delete: if true; }
    match /admin_notes/{docId} { allow read, create, update, delete: if true; }
    match /site_assets/{docId} { allow read, create, update, delete: if true; }


    match /seasonal_campaigns/{docId} { allow read, create, update, delete: if true; }
    match /service_check_results/{docId} { allow read, create, update, delete: if true; }
    match /business_goals/{docId} { allow read, create, update, delete: if true; }
    match /display_settings/{docId} { allow read, write: if true; }


    match /service_prices/{docId} { allow read, create, update, delete: if true; }
    match /after_service_followups/{docId} { allow read, create, update, delete: if true; }
    match /academy_lessons/{docId} { allow read, create, update, delete: if true; }
    match /academy_categories/{docId} { allow read, create, update, delete: if true; }
    match /qr_links/{docId} { allow read, create, update, delete: if true; }
    match /support_tickets/{docId} { allow read, create, update, delete: if true; }

    match /{document=**} { allow read, write: if false; }
  }
}
