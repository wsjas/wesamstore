rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSystemTemplate() {
      return request.resource.data.__system == true
        && request.resource.data.createdBy == 'wesam-auto-setup';
    }

    match /settings/{docId} {
      allow read: if true;
      allow create, update: if docId == 'site';
      allow delete: if false;
    }

    match /config/{docId} {
      allow read: if true;
      allow create, update: if docId == 'site';
      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /orders/{orderId} {
      allow create, read, update, delete: if true;
    }

    match /service_requests/{requestId} {
      allow create, read, update, delete: if true;
    }

    match /contact_messages/{messageId} {
      allow create, read, update, delete: if true;
    }

    match /subscribers/{subscriberId} {
      allow create, read, update, delete: if true;
    }

    match /coupons/{couponId} {
      allow read, create, update, delete: if true;
    }

    match /notifications/{notificationId} {
      allow create, read, update, delete: if true;
    }

    match /accounting_transactions/{txId} {
      allow create, read, update, delete: if true;
    }

    match /expenses/{expenseId} {
      allow create, read, update, delete: if true;
    }

    match /customers/{customerId} {
      allow create, read, update, delete: if true;
    }

    match /technicians/{techId} {
      allow create, read, update, delete: if true;
    }

    match /admin_users/{userId} {
      allow create, read, update, delete: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
