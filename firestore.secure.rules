rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /coupons/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /service_requests/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /contact_messages/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /subscribers/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /notifications/{docId} { allow read, write: if isAdmin(); }
    match /accounting_transactions/{docId} { allow read, write: if isAdmin(); }
    match /expenses/{docId} { allow read, write: if isAdmin(); }
    match /payments/{docId} { allow read, write: if isAdmin(); }
    match /customers/{docId} { allow read, write: if isAdmin(); }
    match /technicians/{docId} { allow read, write: if isAdmin(); }
    match /admin_users/{docId} { allow read, write: if isAdmin(); }
    match /admins/{docId} { allow read, write: if isAdmin(); }
    match /audit_logs/{docId} { allow read, write: if isAdmin(); }
    match /suppliers/{docId} { allow read, write: if isAdmin(); }
    match /purchase_orders/{docId} { allow read, write: if isAdmin(); }
    match /inventory_movements/{docId} { allow read, write: if isAdmin(); }
    match /warranties/{docId} { allow read, write: if isAdmin(); }
    match /work_notes/{docId} { allow read, write: if isAdmin(); }
    match /followups/{docId} { allow read, write: if isAdmin(); }
    match /diagnostics/{docId} { allow read, write: if isAdmin(); }
    match /message_templates/{docId} { allow read, write: if isAdmin(); }
    match /error_logs/{docId} { allow read, write: if isAdmin(); }
    match /archived_records/{docId} { allow read, write: if isAdmin(); }
    match /devices/{docId} { allow read, write: if isAdmin(); }
    match /daily_tasks/{docId} { allow read, write: if isAdmin(); }
    match /button_audits/{docId} { allow read, write: if isAdmin(); }
    match /data_exports/{docId} { allow read, write: if isAdmin(); }
    match /appointments/{docId} { allow read, write: if isAdmin(); }
    match /returns/{docId} { allow read, write: if isAdmin(); }
    match /reviews/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /seo/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /notification_rules/{docId} { allow read, write: if isAdmin(); }
    match /status_templates/{docId} { allow read, write: if isAdmin(); }

    match /homepage_blocks/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /hero_slides/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /loyalty_points/{docId} { allow read, write: if isAdmin(); }
    match /device_handover/{docId} { allow read, write: if isAdmin(); }
    match /service_checklists/{docId} { allow read, write: if isAdmin(); }
    match /admin_notes/{docId} { allow read, write: if isAdmin(); }
    match /site_assets/{docId} { allow read: if true; allow write: if isAdmin(); }


    match /seasonal_campaigns/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /service_check_results/{docId} { allow read, write: if isAdmin(); }
    match /business_goals/{docId} { allow read, write: if isAdmin(); }
    match /display_settings/{docId} { allow read: if true; allow write: if isAdmin(); }


    match /service_prices/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /after_service_followups/{docId} { allow read, write: if isAdmin(); }
    match /academy_lessons/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /academy_categories/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /qr_links/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /support_tickets/{docId} { allow create: if true; allow read, update, delete: if isAdmin(); }
    match /service_contracts/{docId} { allow read, write: if isAdmin(); }
    match /product_discounts/{docId} { allow read, write: if isAdmin(); }
    match /tax_reports/{docId} { allow read, write: if isAdmin(); }
    match /deliveries/{docId} { allow read, write: if isAdmin(); }
    match /backup_snapshots/{docId} { allow read, write: if isAdmin(); }
    match /backup_settings/{docId} { allow read, write: if isAdmin(); }
    match /automation_rules/{docId} { allow read, write: if isAdmin(); }

    match /customer_subscriptions/{docId} { allow read, create, update, delete: if true; }
    match /print_templates/{docId} { allow read, create, update, delete: if true; }
    match /tech_performance_notes/{docId} { allow read, create, update, delete: if true; }
    match /custom_fields/{docId} { allow read, create, update, delete: if true; }
    match /service_quotes/{docId} { allow read, create, update, delete: if true; }
    match /cash_sessions/{docId} { allow read, create, update, delete: if true; }
    match /payroll_commissions/{docId} { allow read, create, update, delete: if true; }
    match /spare_parts/{docId} { allow read, create, update, delete: if true; }
    match /public_bookings/{docId} { allow read, create, update, delete: if true; }
    match /audit_review/{docId} { allow read, create, update, delete: if true; }
    match /communication_settings/{docId} { allow read, create, update, delete: if true; }
    match /customer_risk/{docId} { allow read, create, update, delete: if true; }
    match /branches_locations/{docId} { allow read, create, update, delete: if true; }
    match /staff_attendance/{docId} { allow read, create, update, delete: if true; }
    match /device_registry/{docId} { allow read, create, update, delete: if true; }
    match /customer_portal_logs/{docId} { allow read, create, update, delete: if true; }
    match /role_permissions/{docId} { allow read, create, update, delete: if true; }
    match /database_maintenance_reports/{docId} { allow read, create, update, delete: if true; }
    match /service_quality_reviews/{docId} { allow read, create, update, delete: if true; }
    match /delivery_zones/{docId} { allow read, create, update, delete: if true; }
    match /call_logs/{docId} { allow read, create, update, delete: if true; }
    match /warranty_followups/{docId} { allow read, create, update, delete: if true; }
    match /loaner_devices/{docId} { allow read, create, update, delete: if true; }
    match /document_settings/{docId} { allow read, create, update, delete: if true; }
    match /maintenance_returns/{docId} { allow read, create, update, delete: if true; }
    match /used_parts/{docId} { allow read, create, update, delete: if true; }
    match /field_visits/{docId} { allow read, create, update, delete: if true; }
    match /customer_approvals/{docId} { allow read, create, update, delete: if true; }
    match /admin_link_health/{docId} { allow read, create, update, delete: if true; }
    match /repair_profit_reports/{docId} { allow read, create, update, delete: if true; }

    match /{document=**} { allow read, write: if false; }
  }
}
